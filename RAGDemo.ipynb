        "## Preprocessing Real-World Documents\n",
        "\n",
        "To simulate a real-world pipeline, we will now load documents from PDF files instead of using hardcoded strings. The selected PDF files will be read, and their content will form our `DOCUMENTS` list."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "5a68512f"
      },
      "source": [
        "from pypdf import PdfReader\n",
        "\n",
        "def read_pdf_content(file_path: str) -> str:\n",
        "    \"\"\"Reads a PDF file and extracts its text content.\"\"\"\n",
        "    reader = PdfReader(file_path)\n",
        "    text_content = \"\"\n",
        "    for page in reader.pages:\n",
        "        text_content += page.extract_text() + \"\\n\"\n",
        "    return text_content.strip()"
      ],
      "execution_count": 58,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "0eb8780b",
        "outputId": "2db6beb0-65ce-49bc-e337-b623c4021360"
      },
      "source": [
        "import os\n",
        "\n",
        "# List of selected PDF files\n",
        "pdf_files_to_process = [\n",
        "    \"/content/35f78458-fda9-4486-b457-33d418a9eca5.pdf\",\n",
        "    \"/content/02f12cbd-9474-4623-a1ad-2057885862c1.pdf\",\n",
        "    \"/content/5d8fbf36-7a03-4037-b2a5-024adb2cb2e5.pdf\"\n",
        "]\n",
        "\n",
        "# Initialize an empty DOCUMENTS list\n",
        "DOCUMENTS = []\n",
        "\n",
        "for file_path in pdf_files_to_process:\n",
        "    content = read_pdf_content(file_path)\n",
        "    file_name = os.path.basename(file_path)\n",
        "    title = file_name.replace(\".pdf\", \"\").replace(\"-\", \" \").replace(\"_\", \" \").title() # Basic title extraction\n",
        "\n",
        "    DOCUMENTS.append({\n",
        "        \"title\": title,\n",
        "        \"source\": file_name,\n",
        "        \"content\": content\n",
        "    })\n",
        "\n",
        "print(f\"Successfully loaded {len(DOCUMENTS)} documents from PDF files.\")"
      ],
      "execution_count": 59,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Successfully loaded 3 documents from PDF files.\n"
          ]
        }
      ]
    },
