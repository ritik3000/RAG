        "def rerank(question: str, results: List[Dict], top_k: int = 3) -> List[Dict]:\n",
        "    \"\"\"Rerank results with cross-encoder.\"\"\"\n",
        "    pairs = [(question, r[\"chunk\"]) for r in results]\n",
        "    scores = reranker.predict(pairs)\n",
        "    for r, s in zip(results, scores):\n",
        "        r[\"rerank_score\"] = float(s)\n",
        "    return sorted(results, key=lambda x: x[\"rerank_score\"], reverse=True)[:top_k]"
      ],
      "metadata": {
        "id": "KdP5xsqoEFG8"
      },
      "execution_count": 96,
      "outputs": []
    },
